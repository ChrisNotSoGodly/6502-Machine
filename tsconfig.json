{
    "compilerOptions": {
      "target"              : "ES2017",
      "module"              : "commonjs",
      "rootDir"             : "./src",
      "outDir"              : "./dist",
      "sourceMap"           : true,
      "extendedDiagnostics" : true,
      "skipLibCheck"        : true,
      "forceConsistentCasingInFileNames" : true,
      "strict"              : true,
      "types": ["node"]
    },

    "include": [
        "src/**/*"
    ],
    "exclude": [
      "node_modules",
      "dist"
    ]
}
